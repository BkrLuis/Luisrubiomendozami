Algoritmo IntercambioVariables
    Definir A, B, Auxiliar Como Entero

    Escribir "Ingrese el valor de A:"
    Leer A

    Escribir "Ingrese el valor de B:"
    Leer B

    Auxiliar <- A
    A <- B
    B <- Auxiliar

    Escribir "Realizando el intercambio"
    Escribir "El valor de A es: ", A
    Escribir "El valor de B es: ", B
FinAlgoritmo
